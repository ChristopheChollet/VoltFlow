# Supabase — MÊME projet que GreenOps/FlexSlot (pas un projet séparé)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (test mode) — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Prix récurrent mensuel du produit "VoltFlow Pro" (Stripe > Products)
STRIPE_PRICE_ID_PRO=price_...

# Intégration GreenOps (service-to-service)
# Secret partagé avec GreenOps (header X-VoltFlow-Service-Key)
VOLTFLOW_INTEGRATION_SECRET=dev-integration-secret

# Redirections Stripe Checkout / Billing Portal (côté GreenOps)
CHECKOUT_SUCCESS_URL=http://localhost:3000/billing?checkout=success
CHECKOUT_CANCEL_URL=http://localhost:3000/billing?checkout=cancel
BILLING_PORTAL_RETURN_URL=http://localhost:3000/billing

# Montant stub par ligne d'usage (centimes) — V1, pas de moteur tarifaire réel
USAGE_STUB_AMOUNT_CENTS=50

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000
